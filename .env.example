# Try now button (full URL, no trailing slash). Preferred.
VITE_TRY_NOW_URL=https://staff.pammi.app/register

# Fallback if VITE_TRY_NOW_URL is unset — used as {url}/register
VITE_STAFF_APP_URL=https://staff.pammi.app

# Google Analytics 4
# Property ID (from analytics.google.com URL …/p510143575/…) — for reference only.
VITE_GA_PROPERTY_ID=510143575
# Measurement ID from Admin → Data collection → Data streams → your web stream.
# Looks like G-XXXXXXXXXX — THIS is what the Google tag needs (not the property ID).
VITE_GA_MEASUREMENT_ID=G-73LEVKZ4QP
