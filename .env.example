# Try now / Book a Demo CTA (full URL, no trailing slash). Preferred.
VITE_TRY_NOW_URL=https://staff.pammi.app/register

# Fallback if VITE_TRY_NOW_URL is unset — used as {url}/register
VITE_STAFF_APP_URL=https://staff.pammi.app

# Google Analytics 4
# Property ID (from analytics.google.com URL …/p510143575/…) — for reference only.
VITE_GA_PROPERTY_ID=510143575
# Measurement ID from Admin → Data collection → Data streams → marketing site stream.
# Looks like G-XXXXXXXXXX — different from the patient app (patient.pammi.app) tag.
# Patient app uses its own Measurement ID in careflow-patient; do not reuse that here.
VITE_GA_MEASUREMENT_ID=
